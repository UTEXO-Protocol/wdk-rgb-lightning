    "wdk",
    "wallet",
    "lightning",
    "ldk",
    "bolt11",
    "rgb"
  ],
  "author": "UTEXO",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/UTEXO-Protocol/wdk-rgb-lightning.git"
  },
  "main": "index.js",
  "types": "./index.d.ts",
  "type": "module",
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix"
  },
  "dependencies": {
    "@tetherto/wdk-wallet": "^1.0.0-beta.7",
    "bare-node-runtime": "1.2.0",
    "bip39": "3.1.0"
  },
  "peerDependencies": {
